{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Train Model",
            "type": "shell",
            "command": "${command:python.interpreterPath} src/train.py",
            "group": "build",
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Streamlit App",
            "type": "shell",
            "command": "${command:python.interpreterPath} -m streamlit run streamlit_app/app.py",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        }
    ]
}